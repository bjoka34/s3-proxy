S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_BUCKET=your_bucket_name
S3_ENDPOINT=https://your-s3-endpoint.com
S3_REGION=us-east-1

# Optional: strip this prefix from URL paths before S3 key lookup (e.g. your bucket name)
PATH_PREFIX=your_bucket_name

# Optional: cache duration in seconds (default: 86400 = 1 day)
CACHE_MAX_AGE=86400
